# Локальный Docker: Development
# Сервер/staging: Staging или Production
ASPNETCORE_ENVIRONMENT=Production

# Пользователь PostgreSQL для docker-compose и connection strings сервисов.
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=change-me-long-random-postgres-password

# true запускает EF migrations при старте сервисов.
DATABASE_AUTO_MIGRATE=true

# Учетные данные RabbitMQ для marketplace.events и consumers.
RABBITMQ_USER=marketplace
RABBITMQ_PASS=change-me-long-random-rabbitmq-password

# JWT-контракт общий для Identity и всех API-сервисов.
# JWT_SIGNING_KEY должен быть длинным случайным секретом
JWT_ISSUER=Marketplace.Identity
JWT_AUDIENCE=Marketplace
JWT_SIGNING_KEY=change-me-long-random-jwt-signing-key

# Общий токен для внутренних HTTP-вызовов между сервисами.
# Используется в X-Service-Token сервисами Deals, Payments, Publishers и telegram-publisher.
SERVICE_TOKEN=change-me-long-random-service-token

# Telegram-бот для telegram-publisher.
# TELEGRAM_BOT_TOKEN выдает @BotFather.
# TELEGRAM_BOT_MODE=polling, пока Telegram webhook не настроен.
TELEGRAM_BOT_TOKEN=1234567890:replace_with_botfather_token
TELEGRAM_BOT_MODE=polling

# proxy для Telegram API.
# Оставьте пустым, если сервер имеет прямой доступ к Telegram.
# Примеры:
# TELEGRAM_PROXY_URL=socks5://user:pass@host:port
# TELEGRAM_PROXY_URL=http://user:pass@host:port
TELEGRAM_PROXY_URL=

# Настройки платежей YooKassa.
YOOKASSA_SHOP_ID=replace_with_shop_id
YOOKASSA_SECRET_KEY=test_replace_with_yookassa_secret_key
YOOKASSA_RETURN_URL=https://your-domain.example/payment/return
YOOKASSA_REQUIRE_STATUS_VERIFICATION=true

# Allowlist IP-адресов YooKassa webhook.
# Для production оставьте официальные ranges. Пустые значения отключают IP-фильтр.
YOOKASSA_ALLOWED_IP_1=185.71.76.0/27
YOOKASSA_ALLOWED_IP_2=185.71.77.0/27
YOOKASSA_ALLOWED_IP_3=77.75.153.0/25
YOOKASSA_ALLOWED_IP_4=77.75.156.11
YOOKASSA_ALLOWED_IP_5=77.75.156.35
YOOKASSA_ALLOWED_IP_6=77.75.154.128/25
YOOKASSA_ALLOWED_IP_7=2a02:5180::/32

# Публичные frontend origins, разрешенные backend CORS.
# Локальный Docker frontend http://localhost:3000 уже добавлен в compose.
# Для сервера укажите реальные публичные домены.
FRONTEND_URL=https://your-domain.example
FRONTEND_URL_2=https://www.your-domain.example

# Build-time переменные Vite для frontend Docker image.
# VITE_API_GATEWAY_URL - публичный URL, по которому браузер вызывает API.
# VITE_TELEGRAM_BOT_USERNAME показывается паблишерам при подключении канала.
VITE_API_GATEWAY_URL=https://your-domain.example
VITE_TELEGRAM_BOT_USERNAME=@your_bot_username

# Глобальный fixed-window rate limit на один client IP в минуту.
RATE_LIMIT_PERMIT_LIMIT=360

# Комиссия платформы в basis points. 1000 = 10%, 500 = 5%.
PLATFORM_FEE_BPS=1000

# Host-порты, которые открывает docker-compose.
# Менять только если порты заняты на хосте.
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672
TELEGRAM_PUBLISHER_PORT=5006
