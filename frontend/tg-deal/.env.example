# Скопируйте этот файл в .env.local для локальной Vite-разработки.
# Не коммитьте .env.local.

# Публичный API Gateway URL, который использует браузер.
# Локальный Docker backend:
VITE_API_GATEWAY_URL=http://localhost:5010
# Пример для сервера:
# VITE_API_GATEWAY_URL=https://your-domain.example

# Публичный username Telegram-бота для подсказок при подключении канала.
VITE_TELEGRAM_BOT_USERNAME=@your_bot_username
