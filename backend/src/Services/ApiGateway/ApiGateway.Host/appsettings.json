{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "publishers-route": {
        "ClusterId": "publishers-cluster",
        "Match": { "Path": "/api/v1/publishers/{**catch-all}" }
      },
      "admin-publishers-route": {
        "ClusterId": "publishers-cluster",
        "Match": { "Path": "/api/v1/admin/publishers/{**catch-all}" }
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": { "Path": "/api/v1/catalog/{**catch-all}" }
      },
      "deals-route": {
        "ClusterId": "deals-cluster",
        "Match": { "Path": "/api/v1/deals/{**catch-all}" }
      },
      "admin-deals-route": {
        "ClusterId": "deals-cluster",
        "Match": { "Path": "/api/v1/admin/deals/{**catch-all}" }
      },
      "wallet-route": {
        "ClusterId": "payments-cluster",
        "Match": { "Path": "/api/v1/wallet/{**catch-all}" }
      },
      "pub-wallet-route": {
        "ClusterId": "payments-cluster",
        "Match": { "Path": "/api/v1/publisher/wallet/{**catch-all}" }
      },
      "webhooks-route": {
        "ClusterId": "payments-cluster",
        "Match": { "Path": "/api/v1/webhooks/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": { "destination1": { "Address": "http://identity:8080/" } }
      },
      "publishers-cluster": {
        "Destinations": { "destination1": { "Address": "http://publishers:8080/" } }
      },
      "catalog-cluster": {
        "Destinations": { "destination1": { "Address": "http://channelcatalog:8080/" } }
      },
      "deals-cluster": {
        "Destinations": { "destination1": { "Address": "http://deals:8080/" } }
      },
      "payments-cluster": {
        "Destinations": { "destination1": { "Address": "http://payments:8080/" } }
      }
    }
  }
}
